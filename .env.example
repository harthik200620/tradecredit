# ── Verba · AI Voice & Chat Agents (Sahayak AI) · API keys ───────────────────
# Copy this file to ".env" and fill in your keys. Never commit the real .env.

# Google Gemini — the LLM brain. REQUIRED (the agent can't reason without it).
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional extra Gemini keys — requests are spread round-robin across ALL keys (and rotate
# on a 429 quota), so the free-tier rate limit is effectively multiplied by how many you add.
# IMPORTANT: for this to actually RAISE your limit, each key must be from a DIFFERENT
# Google project/account — keys created in the same project share the same quota.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=
GEMINI_API_KEY_11=
GEMINI_API_KEY_12=
# …slots up to GEMINI_API_KEY_30 are read automatically — just add more lines.

# Sarvam AI — English/Hindi/Telugu speech-to-text (Saaras v3, code-mix). RECOMMENDED.
# Free credits at: https://dashboard.sarvam.ai  (Settings → API Keys)
# If blank, the page falls back to the browser's built-in speech recognition (Chrome/Edge).
SARVAM_API_KEY=

# ElevenLabs — the voice you hear (English lead calls + Hindi collections calls).
# Get the API key at: elevenlabs.io → Profile → API Keys.
# NOTE: Hindi/Telugu are only spoken by the "eleven_v3" model. If your key/plan doesn't have
# v3, the app auto-falls back to Sarvam Bulbul (needs SARVAM_API_KEY above).
ELEVENLABS_API_KEY=
# Optional extra ElevenLabs keys — auto-rotates when one runs out of credits (free tier =
# 10,000 credits/month; one Telugu reply costs ~100-200). Each key is a separate ElevenLabs
# account, and the SAME voice (ELEVENLABS_VOICE_ID below) must be added to that account's
# voice library too, or its requests 404.
ELEVENLABS_API_KEY_2=
ELEVENLABS_API_KEY_3=
ELEVENLABS_VOICE_ID=
# Optional per-language voices (eleven_v3): Hindi and Telugu each get their own voice;
# any left blank falls back to ELEVENLABS_VOICE_ID. NOTE: on a FREE key only premade /
# own-generated voices work via the API — community-library voices need a paid plan.
ELEVENLABS_VOICE_ID_HI=
ELEVENLABS_VOICE_ID_TE=
ELEVENLABS_MODEL_ID=eleven_v3

# ── Knobs (sensible defaults; usually leave as-is) ───────────────────────────
# Which voice speaks first: elevenlabs | sarvam | none
TTS_PROVIDER=elevenlabs
# Sarvam STT model + Bulbul voice for the fallback voice
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka
# The brain. Default "gemini-flash-latest" (NOT the -lite tier) — smarter, more mature, less
# bot-like. "-latest" alias on purpose: pinned ids get retired for newer Google accounts, and
# the rotation pool mixes account ages, so the alias is the only id valid on every key.
GEMINI_MODEL=gemini-flash-latest
# How much the model "thinks" before replying (tokens). Higher = more considered/human, a bit
# slower. 0 = off (instant, more bot-like). 512 is a good balance.
GEMINI_THINKING_BUDGET=512

# Access gate — password to open the pages (defaults to sahayak@ai if unset)
ADMIN_PASSWORD=sahayak@ai
