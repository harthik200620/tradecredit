# ── Sahayak AI · Telugu Voice Agent · API keys ───────────────────────────────
# Copy this file to ".env" and fill in your keys. Never commit the real .env.

# Google Gemini 2.5 Flash — the LLM brain. REQUIRED (the agent can't reason without it).
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional extra Gemini keys — the app auto-rotates to these when one hits its 429 quota.
# IMPORTANT: for rotation to actually RAISE your limit, each key must be from a DIFFERENT
# Google project/account — keys created in the same project share the same quota.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Sarvam AI — Telugu/English speech-to-text (Saaras v3, code-mix). RECOMMENDED.
# Free credits at: https://dashboard.sarvam.ai  (Settings → API Keys)
# If blank, the page falls back to the browser's built-in te-IN speech recognition (Chrome/Edge).
SARVAM_API_KEY=

# ElevenLabs — the voice you hear. Get the API key at: elevenlabs.io → Profile → API Keys.
# NOTE: Telugu is only spoken by the "eleven_v3" model. If your key/plan doesn't have v3,
# the app auto-falls back to Sarvam Bulbul (needs SARVAM_API_KEY above).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_v3

# ── Knobs (sensible defaults; usually leave as-is) ───────────────────────────
# Which voice speaks first: elevenlabs | sarvam | none
TTS_PROVIDER=elevenlabs
# Sarvam STT model + Bulbul voice for the fallback voice
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka
GEMINI_MODEL=gemini-2.5-flash

# Admin gate — password to open the demo page (defaults to sahayak@ai if unset)
ADMIN_PASSWORD=sahayak@ai
